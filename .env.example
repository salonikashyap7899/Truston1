# Example .env file — copy to .env on your VPS and fill in real values (do NOT commit .env)
PORT=3000
NODE_ENV=production

# Supabase — find these in Supabase Dashboard → Settings → API
SUPABASE_URL="https://your-project.supabase.co"
SUPABASE_ANON_KEY="eyJ..."          # anon/public key (JWT starting with eyJ)
SUPABASE_SERVICE_ROLE_KEY="eyJ..."  # service role key (keep secret, server-only)

# These VITE_ prefixed vars are embedded into the client bundle at build time
VITE_SUPABASE_URL="https://your-project.supabase.co"
VITE_SUPABASE_ANON_KEY="eyJ..."     # same as SUPABASE_ANON_KEY above
